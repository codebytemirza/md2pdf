{
  "version": 3,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/api(?:/(.*))$",
      "dest": "/api/index.ts",
      "check": true
    },
    {
      "src": "^(?:/(.*))$",
      "dest": "/index.html",
      "check": true
    }
  ],
  "framework": {
    "version": "6.4.2"
  },
  "crons": []
}
