{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A collaborative workspace for markdown conversions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "teamMembers": { "type": "array", "items": { "type": "string" } },
        "settings": {
          "type": "object",
          "properties": {
            "template": { "type": "string" },
            "paperSize": { "type": "string" },
            "margins": { "type": "string" },
            "customCss": { "type": "string" },
            "watermark": { "type": "string" },
            "signature": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "Conversion": {
      "title": "Conversion",
      "description": "A record of a markdown to pdf conversion",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "userId": { "type": "string" },
        "fileName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "resultUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "userId", "fileName", "status"]
    },
    "User": {
      "title": "User",
      "description": "App user profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "photoURL": { "type": "string" }
      },
      "required": ["email"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification for project updates",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "read"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collaborative projects containing settings and conversion history"
    },
    "/projects/{projectId}/conversions/{conversionId}": {
      "schema": "Conversion",
      "description": "Individual conversion history for a project"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Real-time user notifications"
    }
  }
}
